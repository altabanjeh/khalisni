# Copy this file to .env and fill in real values before running docker-compose.
# In Coolify: set these as Environment Variables in the service dashboard.
# Never commit .env to version control.

# Django
DJANGO_SECRET_KEY=replace-with-a-long-random-string-at-least-50-characters
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com
DJANGO_TIME_ZONE=Asia/Amman
DJANGO_CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
DJANGO_SECURE_SSL_REDIRECT=True
DJANGO_SECURE_HSTS_SECONDS=31536000
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=True
DJANGO_SECURE_HSTS_PRELOAD=True
DJANGO_SESSION_COOKIE_SECURE=True
DJANGO_CSRF_COOKIE_SECURE=True

# PostgreSQL
POSTGRES_DB=khalisni
POSTGRES_USER=khalisni
POSTGRES_PASSWORD=replace-with-a-strong-password
# POSTGRES_HOST and POSTGRES_PORT are set automatically by docker-compose (host=db, port=5432)

# CORS - list origins allowed to call the API directly (not needed when frontend proxies via nginx)
CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
FRONTEND_BASE_URL=https://yourdomain.com

# File uploads (bytes) - default 5 MB
FILE_UPLOAD_MAX_SIZE=5242880

# Initial admin account - created automatically on first startup if set.
# Existing admins are not password-reset unless DJANGO_ADMIN_RESET_PASSWORD=True.
DJANGO_ADMIN_EMAIL=admin@example.com
DJANGO_ADMIN_PASSWORD=replace-with-a-strong-password
DJANGO_ADMIN_NAME=Admin
DJANGO_ADMIN_RESET_PASSWORD=False

# Baseline startup seed.
# This seeds service/catalog data only. It does not create public demo users.
DJANGO_SEED_INITIAL_DATA=False

# Demo data is created manually with:
#   python manage.py seed_demo
# Existing demo passwords are not reset unless you run:
#   python manage.py seed_demo --reset-passwords
# Optional overrides for demo accounts when running the demo seed command:
# DEMO_ADMIN_EMAIL=admin@khalisni.local
# DEMO_ADMIN_PASSWORD=Admin@123
# DEMO_CUSTOMER_EMAIL=customer@khalisni.local
# DEMO_CUSTOMER_PASSWORD=Customer@123
# DEMO_EMPLOYEE_EMAIL=employee@khalisni.local
# DEMO_EMPLOYEE_PASSWORD=Employee@123
# DEMO_PROVIDER_EMAIL=provider@khalisni.local
# DEMO_PROVIDER_PASSWORD=Provider@123

# Cache - omit to use in-process LocMemCache (fine for single-server).
# Set to a Redis URL for multi-process deployments.
# REDIS_URL=redis://redis:6379/0

# Outbound email for password reset and account notifications.
# For local development you can leave the default console backend in place.
# DJANGO_EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
DJANGO_DEFAULT_FROM_EMAIL=no-reply@yourdomain.com
DJANGO_EMAIL_HOST=smtp.your-provider.com
DJANGO_EMAIL_PORT=587
DJANGO_EMAIL_HOST_USER=your-smtp-user
DJANGO_EMAIL_HOST_PASSWORD=replace-with-a-strong-password
DJANGO_EMAIL_USE_TLS=True

# Password reset security controls
PASSWORD_RESET_TOKEN_TTL_SECONDS=1800
PASSWORD_RESET_RATE_LIMIT_WINDOW_SECONDS=1800
PASSWORD_RESET_RATE_LIMIT_EMAIL=3
PASSWORD_RESET_RATE_LIMIT_IP=10

# Gunicorn runtime
GUNICORN_WORKERS=2
GUNICORN_TIMEOUT=120
