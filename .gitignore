# Python
.venv/
__pycache__/
backend/**/__pycache__/
backend/db.sqlite3
*.sqlite3
*.sqlite3.*
*.bak

# Django build artifacts — generated at runtime, never commit
backend/media/
backend/staticfiles/

# Frontend build artifacts
frontend/node_modules/
frontend/dist/
frontend/.npm-cache/
frontend/coverage/

# Secrets — never commit real credentials
.env
backend/.env
*.local.env
mobile/.env
mobile/.env.*

# Mobile / Expo local state
mobile/node_modules/
mobile/.expo/
mobile/dist/
mobile/web-build/

# Logs and local tooling
logs/
*.log
.vscode/
.DS_Store
Thumbs.db
/WhatsApp Image *.jpeg
